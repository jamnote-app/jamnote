[Unit]
Description=JamNote API Server
After=network.target sound.target
Wants=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/jamnote/firmware/api
Environment=PYTHONPATH=/home/pi/jamnote/firmware
ExecStart=/home/pi/jamnote-env/bin/python app.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=jamnote-api

# Allow binding to port 443
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
